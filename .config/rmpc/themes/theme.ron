#![enable(implicit_some)]
#![enable(unwrap_newtypes)]
#![enable(unwrap_variant_newtypes)]
(
    default_album_art_path: None,
    format_tag_separator: " | ",
    browser_column_widths: [20, 38, 42],
    background_color: None,
    modal_backdrop: true,
    text_color: None,
    header_background_color: None,
    modal_background_color: None,
    preview_label_style: (fg: None),
    preview_metadata_group_style: (fg: None),
    song_table_album_separator: None,
    tab_bar: (
        active_style: (fg: None, bg: None, modifiers: "Bold"),
        inactive_style: (fg: None, bg: None),
    ),
    highlighted_item_style: (fg: None, modifiers: "Bold"),
    current_item_style: (fg: None, bg: None, modifiers: "Bold"),
    borders_style: (fg: None, modifiers: "Bold"),
    highlight_border_style: (fg: None),
    symbols: (song: "¾░ØÜ ", dir: "¾▒ŹÖ ", playlist: "¾░▓Ė ", marker: "* ", ellipsis: "...",
        song_style: (fg: None), dir_style: (fg: None),
    ),
    progress_bar: (
        symbols: ["ŅéČ", "Ō¢ł", "Ņé┤", "Ō¢ł", "Ņé┤" ],
        track_style: (fg: None, bg: None),
        elapsed_style: (fg: None, bg: None),
        thumb_style: (fg: None, bg: None),
        use_track_when_empty: false,
    ),
    scrollbar: (
        symbols: ["Ōöŗ", "Ō¢ł", "¾░ä┐", "¾░ä╝"],
        track_style: (fg: None),
        ends_style: (fg: None),
        thumb_style: (fg: None),
    ),
    song_table_format: [
        (
        prop: (kind: Transform(Replace(content: (kind: Sticker("rating")), replacements: [
            (match:  "0", replace: (kind: Group([(kind: Text("¾░ÄĪ"),style: (fg: None))]))),
            (match:  "1", replace: (kind: Group([(kind: Text("¾░Äż"),style: (fg: None))]))),
            (match:  "2", replace: (kind: Group([(kind: Text("¾░Ä¦"),style: (fg: None))]))),
            (match:  "3", replace: (kind: Group([(kind: Text("¾░Ä¬"),style: (fg: None))]))),
            (match:  "4", replace: (kind: Group([(kind: Text("¾░ÄŁ"),style: (fg: None))]))),
            (match:  "5", replace: (kind: Group([(kind: Text("¾░Ä▒"),style: (fg: None))]))),
            (match:  "6", replace: (kind: Group([(kind: Text("¾░Ä│"),style: (fg: None))]))),
            (match:  "7", replace: (kind: Group([(kind: Text("¾░ÄČ"),style: (fg: None))]))),
            (match:  "8", replace: (kind: Group([(kind: Text("¾░Ä╣"),style: (fg: None))]))),
            (match:  "9", replace: (kind: Group([(kind: Text("¾░Ä╝"),style: (fg: None))]))),
            (match: "10", replace: (kind: Group([(kind: Text("¾░ĮĮ"),style: (fg: None))]))),
        ])), default: (kind: Text("’ü©"), style: (fg: "#5e81ac"))),
        width: "3",
        label: "Rating",
        alignment: Center,
            label_prop: (kind: Group([
                (kind: Text("¾░®│"), style: (fg: None)),
            ]))
        ),
        (
            prop: (kind: Sticker("playCount"),style: (fg: None),
                 default: (kind: Text("’ü©"), style: (fg: "#5e81ac"))),
            width: "3",
            alignment: Left,
            label: "Playcount",
            label_prop: (kind: Group([
                (kind: Text("¾░åÖ"), style: (fg: None)),
            ]))
        ),
        (
            prop:(kind: Text("Ōöé"), style: (fg: None)),
            width: "1",
            alignment: Center,
            label: "",
            label_prop: (kind: Group([
                (kind: Text("Ōöé"), style: (fg: None)),
            ]))
        ),
        (
            prop: (kind: Property(Artist), style: (fg: None),
                default: (kind: Text("Unknown Artist"), style: (fg: None))),
            width: "23%",
            label_prop: (kind: Group([
                (kind: Text("Artist "), style: (fg: None)),
                (kind: Text("’ÉĢ"), style: (fg: None))
            ]))
        ),
        (
            prop: (kind: Property(Title), style: (fg: None),
                default: (kind: Property(Filename), style: (fg: None),
                    default: (kind: Text("Unknown Title"), style: (fg: None)))),
            width: "36%",
            label_prop: (kind: Group([
                (kind: Text("Title "), style: (fg: None)),
                (kind: Text("’āČ"), style: (fg: None))
            ]))
        ),
        (
            prop: (kind: Property(Album), style: (fg: None),
                default: (kind: Text("Unknown Album"), style: (fg: None))),
            width: "33%",
            label_prop: (kind: Group([
                (kind: Text("Album "), style: (fg: None)),
                (kind: Text("¾░Ćź"), style: (fg: None))
            ]))
        ),
        (
            prop: (kind: Property(Duration), style: (fg: None),
                default: (kind: Text("-"))),
            width: "8%",
            alignment: Right,
            label_prop: (kind: Group([
                (kind: Text("Length "), style: (fg: None)),
                (kind: Text("’ĆŚ "), style: (fg: None))
            ]))
        ),
    ],
    layout: Split(
        direction: Vertical, panes: [
            (size: "7", borders: "NONE", pane: Component("header")),
            (size: "100%", borders: "NONE", pane: Pane(TabContent)),
            (size: "3", borders: "NONE", pane: Component("progress_bar")),
        ]),
    browser_song_format: [
        (kind: Group([
                    (kind: Property(Track)),
                    (kind: Text(" ")),
                ])),
        (kind: Group([
                    (kind: Property(Artist)),
                    (kind: Text(" - ")),
                    (kind: Property(Title)),
                ]), default: (kind: Property(Filename)))
    ],
    level_styles: (
        info:  (fg: None, bg: None),
        warn:  (fg: "#ebcb8b", bg: None),
        error: (fg: "#bf616a", bg: None),
        debug: (fg: "#d08770", bg: None),
        trace: (fg: None, bg: None),
    ),
    components: {
        "header_line_0": Split(direction: Horizontal, panes: [
                    (size: "12%", borders: "NONE", pane: Component("tab_bar_left")),
                    (size: "76%", borders: "NONE", pane: Pane(Tabs)),
                    (size: "12%", borders: "NONE", pane: Component("tab_bar_right")),
            ]),
        "header_line_1": Split(direction: Horizontal, panes: [
                            (size: "22%", pane: Component("header_element_1")),
                            (size: "1", pane: Component("header_element_space")),
                            (size: "56%", pane: Component("header_element_2")),
                            (size: "1", pane: Component("header_element_space")),
                            (size: "22%", pane: Component("header_element_3")),
                            (size: "2", pane: Component("header_element_right_end")),
            ]),
        "header_line_2": Split(direction: Horizontal, panes: [
                            (size: "22%", pane: Component("header_element_4")),
                            (size: "1", pane: Component("header_element_space")),
                            (size: "56%", pane: Component("header_element_5")),
                            (size: "1", pane: Component("header_element_space")),
                            (size: "22%", pane: Component("header_element_6")),
                            (size: "2", pane: Component("header_element_right_end")),
            ]),
        "header_line_3": Split(direction: Horizontal, panes: [
                            (size: "25%", pane: Component("header_element_7")),
                            (size: "1", pane: Component("header_element_space")),
                            (size: "50%", pane: Component("header_element_8")),
                            (size: "1", pane: Component("header_element_space")),
                            (size: "25%", pane: Component("header_element_9")),
                            (size: "2", pane: Component("header_element_right_end")),

            ]),
        "header": Split(
            direction: Vertical, panes: [
                (size: "2", borders: "TOP | RIGHT | LEFT", border_symbols: Rounded,
                    pane: Split(direction: Horizontal, panes: [
                        (size: "100%", borders: "NONE", pane: Component("header_line_0")),
                  ])
                ),
                (size: "5", borders: "ALL", border_symbols: Library("rounded_collapsed_top"),
                  pane: Split(direction: Vertical, panes: [
                     (size: "100%", borders: "NONE", pane: Component("header_line_1")),
                     (size: "100%", borders: "NONE", pane: Component("header_line_2")),
                     (size: "100%", borders: "NONE", pane: Component("header_line_3")),
                  ])
                ),
            ]
        ),
        "progress_bar": Split(
            direction: Vertical, panes: [
              (size: "3", borders: "ALL", border_symbols: Rounded ,
                  border_title: [
                         (kind: Property(Status(Elapsed)),style: (fg: None)),
                         (kind: Property(Status(StateV2(playing_label: "ŌöĆ¾▒”¤ŌöĆ", paused_label: " ’üī ", stopped_label: " ’üŹ "))),
                             style: (fg: None, modifiers: "Bold")),
                         (kind: Property(Status(Duration)),style: (fg: None))
                      ],
                  border_title_position: Top,
                  border_title_alignment: Center,
                  pane: Split(direction: Vertical, panes: [
                      (size: "100%", borders: "NONE",pane: Pane(ProgressBar)),
                ])
              ),
            ]
        ),
        "tab_bar_left": Split(direction: Horizontal, panes: [
             (size: "100%", pane: Pane(Property(content: [
                             (kind: Text("’üō "), style: (fg: None, modifiers: "Bold")),
                             (kind: Property(Status(StateV2(playing_label: "’üŗ", paused_label: "’üī", stopped_label: "’üŹ"))),
                                 style: (fg: None)),
                             (kind: Text(" ’üö "), style: (fg: None, modifiers: "Bold")),
                             (kind: Property(Song(FileExtension)), style: (fg: None)),
                             (kind: Text(" ")),
                             (kind: Property(Widget(ScanStatus)), style: (fg: None, modifiers: "Bold")),
                             (kind: Text(" ")),
                             (kind: Property(Status(InputBuffer())), style: (fg: None)),
                         ], align: Left))
             ),
            ]),
        "tab_bar_right": Split(direction: Horizontal, panes: [
                 (size: "100%", pane: Pane(Property(content: [
                                 (kind: Transform(Replace(content: (kind: Property(Status(Partition)), style: (fg: None)), replacements: [
                                     (match:  "default", replace: (kind: Group([(kind: Text(""))]))),
                                   ]))),
                                 (kind: Text(" ")),
                                 (kind: Property(Song(Channels())), style: (fg: None),
                                     default: (kind: Text("0"), style: (fg: None))),
                                 (kind: Text(" ¾▒Ī½ "),style: (fg: None)),
                                 (kind: Text("’üō ¾▒Ī¼"), style: (fg: None, modifiers: "Bold")),
                                 (kind: Property(Status(Volume)), style: (fg: None)),
                                 (kind: Text("% ’üö"), style: (fg: None, modifiers: "Bold"))
                             ], align: Right))
                 ),
            ]),
        "header_element_1": Split(
            direction: Horizontal,
            panes: [
               (size: "100%", pane: Pane(Property(content: [
                               (kind: Text("[ "),style: (fg: None, modifiers: "Bold")),
                               (kind: Property(Status(Elapsed)),style: (fg: None)),
                               (kind: Text(" / "),style: (fg: None, modifiers: "Bold")),
                               (kind: Property(Status(Duration)),style: (fg: None)),
                               (kind: Text(" ¾▒”¤"),style: (fg: None, modifiers: "Bold")),
                               (kind: Text(" ]"),style: (fg: None, modifiers: "Bold")),
                           ], align: Left))
               ),
            ]
        ),
        "header_element_2": Split(
            direction: Horizontal,
            panes: [
                (size: "100%", pane: Pane(Property(content: [
                                (kind: Property(Song(Title)), style: (fg: None,modifiers: "Bold"),
                                    default: (kind: Property(Song(Filename)), style: (fg: None,modifiers: "Bold"),
                                        default: (kind: Text("Unknown Title"), style: (fg: None,modifiers: "Bold"))))
                            ], align: Center, scroll_speed: 4))
                ),
            ]
        ),
        
        "header_element_3": Split(
            direction: Horizontal,
            panes: [
               (size: "100%", pane: Pane(Property(content: [
                         (kind: Text("[ "),style: (fg: "#81a1c1", modifiers: "Bold")),
                         (kind: Property(Status(RepeatV2(on_label: "’éČ", off_label: "’éČ",
                                         on_style: (fg: None, modifiers: "Bold"),
                                         off_style: (fg: "#4c566a", modifiers: "Bold"))))),
                         (kind: Text(" | "),style: (fg: "#81a1c1", modifiers: "Bold")),
                         (kind: Property(Status(RandomV2(on_label: "’ü┤", off_label: "’ü┤",
                                         on_style: (fg: None, modifiers: "Bold"),
                                         off_style: (fg: "#4c566a", modifiers: "Bold"))))),
                         (kind: Text(" | "),style: (fg: "#81a1c1", modifiers: "Bold")),
                         (kind: Property(Status(ConsumeV2(on_label: "¾░«»", off_label: "¾░«»", oneshot_label: "¾░«»¾░ćŖ",
                                         on_style: (fg: None, modifiers: "Bold"),
                                         off_style: (fg: "#4c566a", modifiers: "Bold"))))),
                         (kind: Text(" | "),style: (fg: "#81a1c1", modifiers: "Bold")),
                         (kind: Property(Status(SingleV2(on_label: "¾░Äż", off_label: "¾░Ä”", oneshot_label: "¾░ćŖ", off_oneshot_label: "¾▒ģŖ",
                                         on_style: (fg: None, modifiers: "Bold"),
                                         off_style: (fg: "#4c566a", modifiers: "Bold"))))),
                         (kind: Text(" | "),style: (fg: "#81a1c1", modifiers: "Bold")),
                         (kind: Property(Status(Crossfade)),style: (fg: "#4c566a"),
                          default: (kind: Text("¾░┤Į"), style: (fg: "#4c566a"))),
                         (kind: Text(" | "),style: (fg: "#81a1c1", modifiers: "Bold")),
                         (kind: Transform(Replace(content: (kind: Property(Status(InputMode()))), replacements: [
                                 (match:  "Normal", replace: (kind: Group([(kind: Text("N"),style: (fg: "#4c566a", modifiers: "Bold"))]))),
                                 (match:  "Insert", replace: (kind: Group([(kind: Text("I"),style: (fg: None, modifiers: "Bold"))]))),
                             ]))),
                     ], align: Right))
               ),
            ]
        ),

        "header_element_4": Split(
            direction: Horizontal,
            panes: [
                (size: "100%", pane: Pane(Property(content: [
                                (kind: Text("[ "),style: (fg: None, modifiers: "Bold")),
                                (kind: Property(Song(Bits())),default: (kind: Text("Ņ¬Į "), style: (fg: None)), style: (fg: None)),
                                (kind: Text(" bit"),style: (fg: None)),
                                (kind: Text(" | "),style: (fg: None, modifiers: "Bold")),
                                (kind: Property(Status(Bitrate)),default: (kind: Text("Ņ¬Į "), style: (fg: None)),style: (fg: None)),
                                (kind: Text(" kbps"),style: (fg: None)),
                                (kind: Text(" ]"),style: (fg: None, modifiers: "Bold"))
                            ], align: Left))
                ),
            ]
        ),
        "header_element_5": Split(
            direction: Horizontal,
            panes: [
                 (size: "100%", pane: Pane(Property(content: [
                                 (kind: Property(Song(Artist)), style: (fg: None),
                                     default: (kind: Text("Unknown Artist"), style: (fg: None))),
                                 (kind: Text(" - "), style: (fg: None)),
                                 (kind: Property(Song(Album)),style: (fg: None ),
                                     default: (kind: Text("Unknown Album"), style: (fg: None)))
                             ], align: Center, scroll_speed: 4))
                 ),
            ]
        ),
        "header_element_6": Split(
            direction: Horizontal,
            panes: [
                 (size: "100%", pane: Pane(Property(content: [
                                 (kind: Text("[ "),style: (fg: None, modifiers: "Bold")),
                                 (kind: Property(Status(QueueTimeRemaining(separator: " "))),style: (fg: None)),
                                 (kind: Text(" / "),style: (fg: None, modifiers: "Bold")),
                                 (kind: Property(Status(QueueTimeTotal(separator: " "))),style: (fg: None)),
                                 (kind: Text(" ¾▒Ä½"),style: (fg: None, modifiers: "Bold")),
                             ], align: Right))
                 ),
            ]
        ),
        "header_element_7": Split(
            direction: Horizontal,
            panes: [
                  (size: "100%", pane: Pane(Property(content: [
                                  (kind: Text("[ "),style: (fg: None, modifiers: "Bold")),
                                  (kind: Property(Song(SampleRate())),default: (kind: Text("Ņ¬Į "), style: (fg: None)), style: (fg: None)),
                                  (kind: Text(" Hz"),style: (fg: None)),
                                  (kind: Text(" | "),style: (fg: None, modifiers: "Bold")),
                                  (kind: Property(Song(Position)), style: (fg: None),
                                      default: (kind: Text("0"), style: (fg: None))),
                                  (kind: Text(" / "),style: (fg: None, modifiers: "Bold")),
                                  (kind: Property(Status(QueueLength())),style: (fg: None)),
                                  (kind: Text(" ¾░┤Ź"),style: (fg: None, modifiers: "Bold")),
                                  (kind: Text(" ]"),style: (fg: None, modifiers: "Bold"))
                              ], align: Left))
                  ),
            ]
        ),
        "header_element_8": Split(
            direction: Horizontal,
            panes: [
                   (size: "100%", pane: Pane(Property(content: [
                                   (kind: Property(Song(Other("albumartist"))),style: (fg: None),
                                       default: (kind: Text("Unknown Albumartist"), style: (fg: None))),
                                   (kind: Text(" - "), style: (fg: None)),
                                   (kind: Property(Song(Other("composer"))),style: (fg: None),
                                       default: (kind: Text("Unknown Composer"), style: (fg: None))),
                               ], align: Center, scroll_speed: 4))
                   ),
            ]
        ),
        "header_element_9": Split(
            direction: Horizontal,
            panes: [
                   (size: "100%", pane: Pane(Property(content: [
                                   (kind: Text("[ "),style: (fg: None, modifiers: "Bold")),
                                   (kind: Property(Song(Other("date"))),style: (fg: None),
                                       default: (kind: Text("Unknown Date"), style: (fg: None))),
                                   (kind: Text(" | "),style: (fg: None, modifiers: "Bold")),
                                   (kind: Property(Song(Track)),style: (fg: None),
                                       default: (kind: Text("0"), style: (fg: None))),
                                   (kind: Text(" / "),style: (fg: None, modifiers: "Bold")),
                                   (kind: Property(Song(Disc)),style: (fg: None),
                                       default: (kind: Text("0"), style: (fg: None))),
                                   (kind: Text(" ¾░źĀ | "),style: (fg: None, modifiers: "Bold")),
                                   (kind: Property(Song(Other("genre"))),style: (fg: None),
                                       default: (kind: Text("Unknown Genre"), style: (fg: None))),
                               ], align: Right))
                   ),
            ]
        ),
        "header_element_right_end": Split(
            direction: Horizontal,
            panes: [
               (size: "100%", pane: Pane(Property(content: [
                               (kind: Text(" ]"),style: (fg: None, modifiers: "Bold")),
                           ], align: Right))
               ),
            ]
        ),
        "header_element_space": Split(
            direction: Horizontal,
            panes: [
               (size: "100%", pane: Pane(Property(content: [
                               (kind: Text(" ")),
                           ], align: Right))
               ),
            ]
        ),
    },
    cava: (
        bar_symbols: ['Ō¢ü', 'Ō¢é', 'Ō¢ā', 'Ō¢ä', 'Ō¢ģ', 'Ō¢å', 'Ō¢ć', 'Ō¢ł'],
        bar_width: 4, bar_spacing: 1,
        bg_color: None,
        
    ),
    lyrics:(timestamp: false),
    border_symbol_sets: {
    "rounded_collapsed_top": (
        parent: Rounded,
        top_left: "Ōö£",
        top_right: "Ōöż",
        ),
    },
)
